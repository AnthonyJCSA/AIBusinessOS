# ============================================================
# Coriva Core v1.0 — Variables de Entorno
# Copia este archivo a .env.local y completa los valores
# ============================================================

# ── Supabase (REQUERIDO) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenAI (REQUERIDO para IA) ───────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
# Solo server-side — NUNCA exponer con NEXT_PUBLIC_
OPENAI_API_KEY=sk-proj-...

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://coriva-core.vercel.app

# ── WhatsApp ─────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=51913916967

# ── Analytics (OPCIONAL) ─────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ── Notas de configuración ───────────────────────────────────
# 1. Ejecutar migrations en Supabase:
#    - database/corivacore-mvp-schema.sql
#    - database/migrations/001_inventory_cash_rls.sql
#    - database/migrations/002_purchases_suppliers.sql
#    - database/migrations/003_customers_leads_pipeline.sql
#    - database/migrations/004_purchase_number_rls.sql
#    - database/migrations/005_lead_notes_sprint6.sql
#    - database/migrations/006_automations_sprint7.sql
#
# 2. Configurar en Vercel Dashboard:
#    Settings > Environment Variables > Add all above
#
# 3. OPENAI_API_KEY va solo en "Production" y "Preview"
#    NO marcar como "Expose to browser"
