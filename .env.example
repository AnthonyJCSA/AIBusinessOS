# ============================================================
# CORIVA CORE - VARIABLES DE ENTORNO
# ============================================================

# ── SUPABASE (OBLIGATORIO) ──────────────────────────────────
# Obtener de: https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OPENAI (OBLIGATORIO para Asistente IA) ─────────────────
# Obtener de: https://platform.openai.com/api-keys
# IMPORTANTE: Esta es una variable SERVER-ONLY (sin NEXT_PUBLIC_)
OPENAI_API_KEY=sk-proj-...

# ── GOOGLE ANALYTICS (OPCIONAL) ─────────────────────────────
# Google Analytics 4
# Obtener de: https://analytics.google.com/
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Tag Manager
# Obtener de: https://tagmanager.google.com/
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Pixel (Facebook)
# Obtener de: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=

# ── APP CONFIGURATION (OPCIONAL) ────────────────────────────
# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Número de WhatsApp para soporte (sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=51913916967

# ── NUBEFACT (OBLIGATORIO para Facturación) ────────────────
# Obtener de: https://www.nubefact.com/
# IMPORTANTE: Variables SERVER-ONLY (sin NEXT_PUBLIC_)
NUBEFACT_API_URL=https://api.nubefact.com/api/v1/<uuid-empresa>
NUBEFACT_TOKEN=<token-nubefact>

# ── PERÚ API (OBLIGATORIO para DNI/RUC) ────────────────────
# Obtener de: https://peruapi.com/
# IMPORTANTE: Variables SERVER-ONLY (sin NEXT_PUBLIC_)
# Whitelist la IP de salida de Vercel en el dashboard de Perú API
PERUAPI_BASE_URL=https://peruapi.com/api
PERUAPI_KEY=<api-key-peruapi>
PERUAPI_ALLOWED_IP=38.253.149.54

# ============================================================
# NOTAS IMPORTANTES
# ============================================================
#
# Variables NEXT_PUBLIC_*:
#   - Se exponen al navegador (cliente)
#   - Seguras para URLs, IDs públicos, etc.
#   - NO usar para secrets o tokens
#
# Variables sin NEXT_PUBLIC_:
#   - Solo accesibles en servidor
#   - Usar para API keys, tokens, secrets
#   - Nunca se exponen al cliente
#
# Entornos:
#   - .env.local          → Desarrollo local (no commitear)
#   - .env.development    → Desarrollo (opcional)
#   - .env.production     → Producción (configurar en Vercel)
#
# ============================================================
