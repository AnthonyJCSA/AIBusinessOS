# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — Asistente IA (requerido para el chat IA)
# Configurar en Vercel: Settings > Environment Variables
OPENAI_API_KEY=sk-...

# Google Analytics 4
NEXT_PUBLIC_GA4_ID=

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Meta Pixel (opcional)
NEXT_PUBLIC_META_PIXEL_ID=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=51913916967

# Nubefact — Facturación Electrónica (server-side ONLY, sin NEXT_PUBLIC_)
NUBEFACT_API_URL=https://api.nubefact.com/api/v1/<uuid-empresa-nubefact>
NUBEFACT_TOKEN=<token-nubefact>

# Perú API — Consulta DNI y RUC (server-side ONLY, sin NEXT_PUBLIC_)
# Whitelist la IP de salida de Vercel en el dashboard de Perú API
PERUAPI_BASE_URL=https://peruapi.com/api
PERUAPI_KEY=<api-key-peruapi>
PERUAPI_ALLOWED_IP=38.253.149.54
